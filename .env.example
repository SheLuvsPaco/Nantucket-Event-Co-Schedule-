# App identity
APP_NAME="Nantucket Event Co."
COMPANY_NAME="Nantucket Event Co."
COMPANY_TIMEZONE="America/New_York"
COMPANY_WEBSITE_URL="https://nantucketeventco.com/tent-rentals/"

# Authentication
# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-a-long-random-value"
SESSION_COOKIE_NAME="porter_session"
DEMO_MODE="true"

# Database
# Local development:
DATABASE_URL="file:./porter.db"
# Turso/libSQL production deployments can use:
# DATABASE_URL="libsql://your-database.turso.io"
DATABASE_AUTH_TOKEN=""

# AI Quick Add
OPENAI_API_KEY=""
# Optional override. Defaults to gpt-4o.
OPENAI_MODEL="gpt-4o"

# Seed accounts. Change these before using the app with real data.
SEED_ADMIN_EMAIL="admin@porter.local"
SEED_ADMIN_PASSWORD="ChangeMeAdmin123!"
SEED_OWNER_EMAIL="owner@porter.local"
SEED_OWNER_PASSWORD="ChangeMeOwner123!"
SEED_STAFF_EMAIL="staff@porter.local"
SEED_STAFF_PASSWORD="ChangeMeStaff123!"

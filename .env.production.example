# Copy these values into the production deployment platform.
# Never commit a real .env.production file or real credentials.

APP_NAME="Nantucket Event Co."
COMPANY_NAME="Nantucket Event Co."
COMPANY_TIMEZONE="America/New_York"
COMPANY_WEBSITE_URL="https://nantucketeventco.com/tent-rentals/"

# Generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-a-production-random-secret"
SESSION_COOKIE_NAME="nantucket_event_session"
DEMO_MODE="false"

# Use persistent remote libSQL in production. A local file is not durable on
# serverless deployments. The Vercel Turso integration may provide these as
# TURSO_DATABASE_URL and TURSO_AUTH_TOKEN; the app supports both names.
DATABASE_URL="libsql://your-production-database.turso.io"
DATABASE_AUTH_TOKEN="replace-with-production-database-token"

# Added automatically when a Vercel Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-read-write-token"

# Use a separate private Blob store for sensitive invoice documents.
INVOICE_BLOB_READ_WRITE_TOKEN="replace-with-private-vercel-blob-token"

OPENAI_API_KEY="replace-with-production-openai-key"
OPENAI_MODEL="gpt-4o"

# Generate one VAPID key pair and keep it unchanged between deployments.
# Command: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="replace-with-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-vapid-private-key"
VAPID_SUBJECT="mailto:operations@nantucketeventco.com"

# Vercel sends this value as a Bearer token when invoking scheduled reminders.
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-a-production-random-secret"

# These values are used only when intentionally seeding initial accounts.
SEED_ADMIN_EMAIL="admin@your-company-domain.com"
SEED_ADMIN_PASSWORD="replace-with-a-unique-production-password"
SEED_OWNER_EMAIL="owner@your-company-domain.com"
SEED_OWNER_PASSWORD="replace-with-a-unique-production-password"
SEED_STAFF_EMAIL="staff@your-company-domain.com"
SEED_STAFF_PASSWORD="replace-with-a-unique-production-password"

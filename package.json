{
  "name": "porter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "scripts": {
    "dev": "env -u OPENAI_API_KEY next dev",
    "dev:3003": "env -u OPENAI_API_KEY next dev -p 3003",
    "pwa:prepare": "node scripts/build-service-worker.mjs",
    "pwa:verify": "node scripts/verify-pwa.mjs",
    "build": "npm run pwa:prepare && next build",
    "start": "next start",
    "start:3003": "next start -p 3003",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:copy": "tsx scripts/copy-database.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run pwa:verify"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.73",
    "@libsql/client": "^0.17.4",
    "@vercel/blob": "^2.4.1",
    "ai": "^6.0.208",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
